{
    "name": "@d1vij/shit-i-always-use",
    "version": "0.1.19",
    "description": "Hooks, Functions and Types that I always use",
    "homepage": "https://github.com/d1vij/shit-i-always-use#readme",
    "publishConfig": {
        "access": "public"
    },
    "bugs": {
        "url": "https://github.com/d1vij/shit-i-always-use/issues"
    },
    "sideEffects": false,
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/d1vij/shit-i-always-use.git"
    },
    "workspaces": [
        "test/**"
    ],
    "files": [
        "dist"
    ],
    "type": "module",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/vanilla/index.d.ts",
                "default": "./dist/vanilla/index.js"
            }
        },
        "./package.json": "./package.json",
        "./svelte": {
            "types": "./dist/svelte/index.d.ts",
            "import": "./dist/svelte/index.js"
        },
        "./react": {
            "types": "./dist/react/index.d.ts",
            "import": "./dist/react/index.js"
        }
    },
    "scripts": {
        "build": "bun run build.ts",
        "dev": "bun run --cwd test/ui dev",
        "format": "biome format --write",
        "lint": "biome check --fix",
        "prepare": "bun simple-git-hooks",
        "release": "bumpp --commit --push --tag",
        "test": "bun test",
        "test:coverage": "bun test --coverage",
        "test:watch": "bun test --watch",
        "type-check": "tsc --noEmit",
        "prepack": "bun run build"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.11",
        "@types/bun": "^1.3.12",
        "@types/react": "^19.2.14",
        "bumpp": "^10.4.1",
        "bunup": "^0.16.31",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "simple-git-hooks": "^2.13.1",
        "typescript": "^6.0.2"
    },
    "peerDependencies": {
        "radashi": "^12.7.2",
        "react": "^18.0.0 || ^19.0.0",
        "react-dom": "^18.0.0 || ^19.0.0",
        "svelte": "^5.55.2",
        "typescript": ">=4.5.0"
    },
    "peerDependenciesMeta": {
        "typescript": {
            "optional": true
        }
    },
    "simple-git-hooks": {
        "pre-commit": "bun run lint && bun run type-check"
    },
    "dependencies": {
        "@sveltejs/package": "^2.5.7",
        "clsx": "^2.1.1",
        "nanoid": "^5.1.7",
        "svelte-package": "^0.1.0",
        "tailwind-merge": "^3.5.0"
    }
}
